NODE_ENV=development
PORT=5000
# If your Atlas password contains special characters, URL-encode it before placing it in the URI.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
ADMIN_USERNAME=Admin
ADMIN_PASSWORD=ChangeThisAdminPassword123!
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=admin@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=admin@example.com
CLIENT_ORIGIN=http://localhost:5173
# Production:
# CLIENT_ORIGIN=https://app.rk-lawassociates.co.in,https://rkassociates-frontend.vercel.app
